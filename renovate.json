{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "automerge": true,
  "automergeType": "branch",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],
  "minimumReleaseAge": "7 days",
  "schedule": ["* 9-23 * * *"],
  "automergeSchedule": ["* 9-23 * * *"]
}
